#!/usr/bin/env bash
# Author: Castro-Fidel (linux-gaming.ru)
########################################################################
# функция вывода ошибки
print_error () {
    echo "ERROR: $@"
}
# функция вывода информации
print_info () {
    echo "INFO: $@"
}
# функция вывода переменных
print_var () {
    for vp in $@ ; do echo "${vp}=${!vp}" ; done
}
# функция копирования файла 
try_copy_file () {
    if [ ! -f "$1" ] ; then	print_info "file $1 not found for copy" && return 1
    elif [ -z "$2" ] ; then	print_error "no way to copy file $1" && return 1
    else
        cp -f "$1" "$2"
        if [ "$?" != 0 ]
        then print_error "failed to copy file $1 to $2" || return 1
        else return 0
        fi
    fi
}
# функция копирования каталога
try_copy_dir () {
    if [ ! -d "$1" ] ; then	print_info "directory $1 not found for copy"
    elif [ -z "$2" ] ; then	print_error "no way to copy directory $1"
    else
        cp -fr "$1" "$2"
        [ "$?" != 0 ] && print_error "failed to copy directory $1 to $2" || return 0
    fi
    return 1
}
# функция удаления файла 
try_remove_file () {
    if [ -f "$1" ] ; then
        rm -f "$1"
        [ "$?" == 0 ] && return 0 || return 1
    fi
}
# функция удаления директории
try_remove_dir () {
    if [ -d "$1" ] ; then
        rm -fr "$1"
        [ "$?" == 0 ] && return 0 || return 1
    fi
}
# функция создания символьной ссылки на файл
try_force_link_file () {
    if [ ! -f "$1" ] ; then :
    elif [ -z "$2" ] ; then	print_error "no way to link file $1"
    else
        ln -sf "$1" "$2"
        [ "$?" != 0 ] && print_error "failed to link file $1 to $2" || return 0
    fi
    return 1
}
# функция проверки символьной ссылки
check_symlink () {
    CHK_SYMLINK_FILE="`file "$1"`"
    if [[ ! -z "`echo "$CHK_SYMLINK_FILE" | grep -v "broken" | grep "symbolic link to" | awk '{print $1}'`" ]] ; then
        return 0
    elif [[ ! -z "`echo "$CHK_SYMLINK_FILE" | grep "broken symbolic link to" | awk '{print $1}'`" ]] ; then
        print_error "remove broken symlink: $CHK_SYMLINK_FILE"
        rm -fr "$CHK_SYMLINK_FILE"
        return 1
    else
        return 1
    fi
}
# функция создания символьной ссылки на каталог
try_force_link_dir () {
    if [ ! -d "$1" ] ; then	print_info "directory $1 not found for link"
    elif [ -z "$2" ] ; then	print_error "no way to link directory $1"
    else
        ln -sf "$1" "$2"
        [ "$?" != 0 ] && print_error "failed to link directory $1 to $2" || return 0
    fi
    return 1
}
# функция проверки каталога (первый аргумен) с выводом в файл (второй аргумент), третий аргумент является условием для case (выборки)
parsing_dir () {
    if [[ -d "$1" ]] ; then
        orig_IFS="$IFS"
        IFS=$'\n'
        try_remove_file "$2"
        for par_dir in $(ls -1 "$1") ; do
            if [[ -n "${par_dir}" ]] ; then
                par_dir_new=`echo "${par_dir}" | awk '$1=$1' | sed -e s/[[:blank:]]/_/g`
                case "$3" in
                proton)
                    echo "${par_dir_new^^}=\"$(dirname "`readlink -f "$1/$par_dir"`")/$par_dir/file\"" | grep -i "proton" | grep -v "Runtime" >> "$2" ;;
                portproton_autoinstall)
                    echo "${par_dir}" | grep -v ".png" >> "$2" ;;
                *)
                    echo "${par_dir_new^^}=\"$(dirname "`readlink -f "$1/$par_dir"`")/$par_dir\"" >> "$2" ;;
                esac
            else
                return 1
            fi
        done
        IFS="$orig_IFS"
    else
        return 1
    fi
    return 0
}
# функция проверки запущен ли процесс (первый аргумен)
check_process () {
    [ ! -n "`ps cax | grep "$1" | awk '{print $1}'`" ] && return 0 || return 1 
}
# функция в скачивания с индикацией прогресса с помощью zenity ($1 - ссылка, $2 - в какой файл) 
try_download () {
    PP_DOWNLOAD_FILE_NAME="$(basename $1)"
    set -o pipefail
    wget -O "$2" --read-timeout 300 --retry-connrefused --timeout 15 --tries 2 \
    --user-agent="Mozilla/5.0 (compatible; Konqueror/2.1.1; X11)" "${1}" 2>&1 | \
    tr '\r' '\n' | sed -u 's/.* \([0-9]\+%\)\ \+\([0-9,.]\+.\) \(.*\)/\1\n#Downloading at \1\/, \2\/s, ETA \3/; s/^20[0-9][0-9].*/#Done./' | \
    zenity --progress --percentage=0 --title="Download ${PP_DOWNLOAD_FILE_NAME}" --text=Starting... --auto-close --width=500 --height=90
    if [ "${PIPESTATUS[0]}" != 0 ] ; then
        print_error "Failed to download ${PP_DOWNLOAD_FILE_NAME} from GitHub."
        print_info "Try download ${PP_DOWNLOAD_FILE_NAME} from FTP"
        try_remove_file "$2"
        wget -O "$2" --read-timeout 300 --retry-connrefused --timeout 15 --tries 2 \
        --user-agent="Mozilla/5.0 (compatible; Konqueror/2.1.1; X11)" --ftp-user=anonymous "ftp://171.22.215.18/archives/${PP_DOWNLOAD_FILE_NAME}" 2>&1 | \
        tr '\r' '\n' | sed -u 's/.* \([0-9]\+%\)\ \+\([0-9,.]\+.\) \(.*\)/\1\n#Downloading at \1\/, \2\/s, ETA \3/; s/^20[0-9][0-9].*/#Done./' | \
        zenity --progress --percentage=0 --title="Download ${PP_DOWNLOAD_FILE_NAME}" --text=Starting... --auto-close --width=500 --height=90
        if [ "${PIPESTATUS[0]}" != 0 ] ; then
            print_error "Failed to download ${PP_DOWNLOAD_FILE_NAME} from FTP."
            try_remove_file "$2"
            return 1   
        fi
    fi
    try_remove_file "${PORT_PROTON_TMP_PATH}/download_log"
    return 0
}
# функция в скачивания с индикацией прогресса с помощью zenity ($1 - ссылка, $2 - в какой каталог) 
try_download_to_path () {
    set -o pipefail
    wget --directory-prefix="$2" --read-timeout 300 --retry-connrefused --timeout 15 --tries 3 \
    --user-agent="Mozilla/5.0 (compatible; Konqueror/2.1.1; X11)" "$1" 2>&1 | \
    tr '\r' '\n' | sed -u 's/.* \([0-9]\+%\)\ \+\([0-9,.]\+.\) \(.*\)/\1\n#Downloading at \1\/, \2\/s, ETA \3/; s/^20[0-9][0-9].*/#Done./' | \
    zenity --progress --percentage=0 --title="Download $(basename $1)" --text=Starting... --auto-close --width=500 --height=90
    if [ "${PIPESTATUS[0]}" != 0 ] ; then
        print_error "Failed to download $1."
        return 1 
    else 
        return 0
    fi
}
# функция в скачивания без индикации ($1 - ссылка, $2 - в какой файл) 
try_download_silent () {
    wget -O "$2" --read-timeout 300 --retry-connrefused --timeout 15 --tries 3 \
    --user-agent="Mozilla/5.0 (compatible; Konqueror/2.1.1; X11)" "$1"
    if [ "${PIPESTATUS[0]}" != 0 ] ; then
        print_error "Failed to download $1. Skipping."
        try_remove_file "$2"
        return 1 
    else 
        return 0
    fi
}

create_new_dir () {
    if [ ! -d "$1" ] ; then
        mkdir -p "$1"
    fi
    return 0
}

var_winedlloverride_update () {
    if [ ! -z "${WINEDLLOVERRIDES}" ]
    then export WINEDLLOVERRIDES="${1};${WINEDLLOVERRIDES}"
    else export WINEDLLOVERRIDES="${1}"
    fi
    return 0
}

var_vkd3d_config_update () {
    if [ ! -z "${VKD3D_CONFIG}" ]
    then export VKD3D_CONFIG="${1};${VKD3D_CONFIG}"
    else export VKD3D_CONFIG="${1}"
    fi
    return 0
}

var_radv_perftest_config_update () {
    if [ ! -z "${RADV_PERFTEST}" ]
    then export RADV_PERFTEST="${1};${RADV_PERFTEST}"
    else export RADV_PERFTEST="${1}"
    fi
    return 0
}

var_vk_istance_layers_config_update () {
    if [ ! -z "${PP_VK_INSTANCE_LAYERS}" ]
    then export PP_VK_INSTANCE_LAYERS="${1}:${PP_VK_INSTANCE_LAYERS}"
    else export PP_VK_INSTANCE_LAYERS="${1}"
    fi
    return 0
}

unpack_tar_zst () {
    set -o pipefail
    unset PP_ZSTD_PORT
    if  [[ `which zstd` ]] &>/dev/null ; then
        tar -I zstd -xhvf "$1" -C "$2" | sszen
        [ "${PIPESTATUS[0]}" != 0 ] && print_error "File $1 unpacking error." && return 1 || return 0
    else
        print_error "zstd not found." && return 1
    fi
}

unpack_tar_xz () {
    set -o pipefail
    tar -Jxhvf "$1" -C "$2" | sszen
    [ "${PIPESTATUS[0]}" != 0 ] && print_error "File $1 unpacking error." && return 1 || return 0
}

unpack_tar_gz () {
    set -o pipefail
    tar -xhzvf "$1" -C "$2" | sszen
    [ "${PIPESTATUS[0]}" != 0 ] && print_error "File $1 unpacking error." && return 1 || return 0
}

unpack_tar () {
    set -o pipefail
    tar -xhvf "$1" -C "$2" | sszen
    [ "${PIPESTATUS[0]}" != 0 ] && print_error "File $1 unpacking error." && return 1 || return 0
}

PP_clear_pfx () {
    try_remove_file "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/system.reg"
    try_remove_file "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/user.reg"
    try_remove_file "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/userdef.reg"
    try_remove_file "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/winetricks.log"
    try_remove_file "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/.update-timestamp"
    try_remove_file "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/.windows-serial"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/windows/"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/ProgramData/Setup"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/ProgramData/Windows"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/ProgramData/WindowsTask"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/ProgramData/Package Cache"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/Public/Local Settings/Application Data/Microsoft"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/Public/Local Settings/Application Data/Temp"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/Public/Local Settings/Temporary Internet Files"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/Public/Application Data/Microsoft"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/Public/Application Data/wine_gecko"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/Public/Temp"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/steamuser/Local Settings/Application Data/Microsoft"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/steamuser/Local Settings/Application Data/Temp"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/steamuser/Local Settings/Temporary Internet Files"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/steamuser/Application Data/Microsoft"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/steamuser/Application Data/wine_gecko"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/users/steamuser/Temp"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files/Internet Explorer"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files/Windows Media Player"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files/Windows NT"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files/Common Files"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files (x86)/Internet Explorer"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files (x86)/Common Files"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files (x86)/Windows Media Player"
    try_remove_dir "${PORT_PROTON_PATH}/data/prefixes/${PP_PREFIX_NAME}/drive_c/Program Files (x86)/Windows NT"
